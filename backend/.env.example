# Solana RPC endpoint
# Use https://api.devnet.solana.com for devnet or https://api.mainnet-beta.solana.com for mainnet
RPC_URL=https://api.devnet.solana.com

# Program ID — replace with your deployed sss-core program ID
PROGRAM_ID=YOUR_PROGRAM_ID_HERE

# Mint address — replace with the mint created by `sss-token init`
MINT=YOUR_MINT_ADDRESS_HERE

# Authority keypair — path to the JSON keypair file that initialized the stablecoin
KEYPAIR_PATH=~/.config/solana/id.json

# Server
PORT=3000
HOST=0.0.0.0

# Logging (debug | info | warn | error)
LOG_LEVEL=info

# Event listener poll interval (ms)
POLL_INTERVAL_MS=5000

# Database path (default: ./data/sss.db)
# DB_PATH=./data/sss.db
